@page
@model RiviuFood.Web.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="max-w-md mx-auto mt-8 bg-white p-6 rounded-2xl shadow">
    <h1 class="text-2xl font-bold mb-6">Tạo tài khoản</h1>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div>
            <label asp-for="Input.FullName" class="form-label"></label>
            <input asp-for="Input.FullName" class="form-control" autocomplete="name" placeholder="Họ và tên"/>
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Email"/>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" type="password" placeholder="Mật khẩu"/>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" type="password" placeholder="Xác thực mật khẩu" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <button id="registerSubmit" type="submit" class="w-full btn btn-primary">Đăng ký</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
