@model RiviuFood.Web.Models.ViewModels.PostCreateVM

<div class="container mx-auto px-4 py-10 max-w-2xl">
    <h2 class="text-3xl font-black mb-8 text-gray-900">✍️ Đăng bài Review mới</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-6">
        <div>
            <label class="block font-bold text-gray-700 mb-2">Tiêu đề bài viết</label>
            <input asp-for="Title" class="w-full p-4 border rounded-2xl focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Ví dụ: Cà phê muối ngon nhất quận 1..." />
            <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label class="block font-bold text-gray-700 mb-2">Chọn quán Cafe</label>
            <select asp-for="RestaurantId" asp-items="Model.Restaurants" class="w-full p-4 border rounded-2xl outline-none">
                <option value="">-- Chọn quán Boss vừa ghé --</option>
            </select>
        </div>

        <div>
            <label class="block font-bold text-gray-700 mb-2">Đánh giá sao</label>
            <input type="number" asp-for="Rating" min="1" max="5" class="w-24 p-4 border rounded-2xl outline-none" />
        </div>

        <div>
            <label class="block font-bold text-gray-700 mb-2">Ảnh check-in</label>
            <input type="file" name="ImageFile" class="w-full" />
        </div>

        <div>
            <label class="block font-bold text-gray-700 mb-2">Nội dung review</label>
            <textarea asp-for="Content" rows="6" class="w-full p-4 border rounded-2xl outline-none" placeholder="Chia sẻ trải nghiệm của Boss..."></textarea>
        </div>

        <button type="submit" class="w-full bg-orange-600 text-white font-black py-4 rounded-full hover:bg-orange-700 shadow-lg transition">
            ĐĂNG BÀI NGAY 🚀
        </button>
    </form>
</div>