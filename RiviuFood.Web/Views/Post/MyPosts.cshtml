@using X.PagedList;
@using X.PagedList.Mvc.Core;
@model IPagedList<RiviuFood.Web.Models.Entities.Post>

<div class="bg-gray-50 min-h-screen pb-12">
    <div class="bg-white shadow-sm mb-8 pb-8">
        <div class="w-full h-64 md:h-80 overflow-hidden relative bg-gray-200">
            <img src="https://images.unsplash.com/photo-1493770348161-369560ae357d?q=80&w=2070&auto=format&fit=crop"
                 alt="Cover Photo" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-black/20"></div>
        </div>

        <div class="max-w-6xl mx-auto px-4 relative -mt-20 sm:-mt-24 flex flex-col items-center">
            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-white shadow-lg overflow-hidden bg-white flex items-center justify-center text-4xl font-black text-orange-500">
                @User.Identity?.Name?.Substring(0, 1).ToUpper()
            </div>
            
            <h2 class="text-2xl md:text-3xl font-black text-gray-900 mt-4">@User.Identity?.Name</h2>
            <p class="text-gray-500 font-medium mt-1">@("@")@User.Identity?.Name?.ToLower().Replace(" ", "") • Chuyên gia ẩm thực</p>
            
            <div class="flex space-x-8 mt-6">
                <div class="text-center">
                    <span class="block text-xl font-black text-gray-900">@Model.TotalItemCount</span>
                    <span class="text-sm text-gray-500 font-medium">Bài Review</span>
                </div>
                <div class="text-center">
                    <span class="block text-xl font-black text-gray-900">128</span>
                    <span class="text-sm text-gray-500 font-medium">Người theo dõi</span>
                </div>
                <div class="text-center">
                    <span class="block text-xl font-black text-gray-900">45</span>
                    <span class="text-sm text-gray-500 font-medium">Đang theo dõi</span>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold text-gray-900">Bài viết của Boss</h3>
            <a asp-action="Create" class="bg-orange-600 text-white px-5 py-2 rounded-full font-bold shadow hover:bg-orange-700 transition">
                + Thêm bài mới
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                @foreach (var post in Model)
                {
                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300 relative group border border-gray-100">
                        <div class="absolute top-2 right-2 z-10 flex flex-col space-y-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a asp-action="Edit" asp-route-id="@post.Id" class="w-8 h-8 bg-white/90 backdrop-blur rounded-full flex items-center justify-center text-blue-600 shadow hover:bg-blue-50">
                                ✏️
                            </a>
                            <a asp-action="Delete" asp-route-id="@post.Id" class="w-8 h-8 bg-white/90 backdrop-blur rounded-full flex items-center justify-center text-red-600 shadow hover:bg-red-50" onclick="return confirm('Boss có chắc muốn xóa bài này không?');">
                                🗑️
                            </a>
                        </div>

                        <div class="aspect-w-1 aspect-h-1 w-full h-48 sm:h-56 overflow-hidden relative">
                            <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/images/no-image.jpg" : post.ImageUrl)"
                                 class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                            <div class="absolute bottom-2 left-2 bg-black/60 backdrop-blur px-2 py-1 rounded-lg text-white text-xs font-bold flex items-center shadow">
                                <span class="text-orange-400 mr-1">⭐</span> @post.Rating
                            </div>
                        </div>

                        <div class="p-4">
                            <p class="text-[11px] font-bold text-orange-600 uppercase tracking-wider mb-1 line-clamp-1">📍 @post.Restaurant?.Name</p>
                            <h4 class="font-bold text-gray-900 text-sm md:text-base line-clamp-2 hover:text-orange-600">
                                <a asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                            </h4>
                            <div class="flex items-center justify-between mt-3">
                                <span class="text-xs text-gray-400">@post.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <span class="text-xs text-gray-500 font-medium">💬 @post.Comments?.Count()</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-10 flex justify-center pagination-container">
                @Html.PagedListPager(Model, page => Url.Action("MyPosts", new { page }),
                    new PagedListRenderOptions
                    {
                        LiElementClasses = new string[] { "mx-1" },
                        PageClasses = new string[] { "px-4 py-2 rounded-lg bg-white border border-gray-200 text-gray-700 hover:bg-orange-500 hover:text-white transition font-bold" },
                        UlElementClasses = new string[] { "flex items-center" }
                    })
            </div>

            <style>
                        /* Bắt thẳng vào class 'active' mặc định của thư viện */
                        .pagination-container .active a,
                        .pagination-container .active span {
                            background-color: #ea580c !important;
                            color: white !important;
                            border-color: #ea580c !important;
                        }
            </style>
        }
        else
        {
            <div class="text-center py-20 bg-white rounded-3xl border border-gray-100">
                <div class="text-6xl mb-4">🍽️</div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Trang cá nhân hơi trống vắng!</h4>
                <p class="text-gray-500 mb-6">Boss chưa đăng bài review nào. Khám phá món ngon và chia sẻ ngay nhé.</p>
                <a asp-action="Create" class="bg-orange-600 text-white px-8 py-3 rounded-full font-bold shadow hover:bg-orange-700 transition">Viết Review Đầu Tiên</a>
            </div>
        }
    </div>
</div>