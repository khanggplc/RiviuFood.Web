@model IEnumerable<RiviuFood.Web.Models.Entities.Post>
<div class="container mx-auto px-4 pt-6">
    <!-- Search-->
    <div class="mb-10 max-w-4xl mx-auto">
        <form asp-action="Index" method="get" class="relative group">
            <input type="text" name="searchString" value="@ViewBag.CurrentSearch"
                   class="w-full pl-14 pr-32 py-5 bg-white border-2 border-gray-100 rounded-[2rem] shadow-xl shadow-gray-100/50 outline-none focus:border-orange-500 transition-all text-lg"
                   placeholder="Tìm tên quán, món ăn hoặc tiêu đề..." />
            
            <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
                <span class="text-2xl">🔍</span>
            </div>

            <button type="submit" class="absolute right-3 top-2 bottom-2 bg-orange-600 text-white px-8 rounded-[1.5rem] font-black hover:bg-orange-700 transition shadow-lg shadow-orange-200">
                TÌM
            </button>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
        {
            <div class="mt-4 text-center">
                <p class="text-gray-500">
                    Đang hiện kết quả cho: <span class="font-bold text-orange-600">"@ViewBag.CurrentSearch"</span>
                    <a href="/" class="ml-2 text-xs text-gray-400 underline hover:text-red-500">Xóa tìm kiếm</a>
                </p>
            </div>
        }
    </div>
</div>
<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-10">
        <h2 class="text-3xl font-black text-gray-900">🔥 Khám phá món ngon</h2>
        <a asp-controller="Post" asp-action="Create" class="bg-orange-600 text-white px-6 py-3 rounded-full font-bold shadow-lg hover:bg-orange-700 transition">
            + Viết Review
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var post in Model)
        {
            <div class="bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 group">
                <div class="relative h-64 overflow-hidden">
                    <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/images/no-image.jpg" : post.ImageUrl)"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-orange-600">
                        ⭐ @post.Rating / 5
                    </div>
                </div>

                <div class="p-6">
                    <span class="text-blue-600 text-xs font-bold uppercase tracking-wider">@post.Restaurant?.Name</span>
                    <h3 class="text-xl font-bold text-gray-900 mt-1 mb-3 line-clamp-1">
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="hover:text-orange-600">
                            @post.Title
                        </a>
                    </h3>
                    <p class="text-gray-500 text-sm line-clamp-2 mb-4">@post.Content</p>
                    
                    <div class="flex items-center justify-between mt-3">
                        <div class="flex items-center space-x-2">
                            <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold">B</div>
                            <span class="text-xs text-gray-500">@post.User?.Email</span>
                        </div>

                        <div class="flex items-center space-x-3">
                            <button class="like-btn flex items-center space-x-1 text-gray-400 hover:text-red-500 transition duration-200 focus:outline-none"
                                    data-post-id="@post.Id">
                                <span class="heart-icon text-sm">🖤</span>
                                <span class="like-count font-bold text-xs">@(post.PostLikes?.Count() ?? 0)</span>
                            </button>

                            <span class="text-xs text-gray-400">💬 @post.Comments?.Count()</span>

                            <span class="text-[10px] text-gray-400">@post.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</div>