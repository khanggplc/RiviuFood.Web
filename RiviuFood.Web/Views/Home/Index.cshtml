@model IEnumerable<RiviuFood.Web.Models.Entities.Post>

@{
    ViewData["Title"] = "Trang chủ Riviu";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Khám phá đồ uống mới nhất</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden transition-transform hover:scale-105 border border-gray-100">
                <div class="h-48 bg-gray-200 relative">
                    <img src="https://images.unsplash.com/photo-1541167760496-162955ed8a9f?w=500"
                         class="w-full h-full object-cover" alt="Drink Image">
                    <span class="absolute top-3 right-3 bg-yellow-400 text-white px-3 py-1 rounded-full text-sm font-bold shadow-md">
                        ⭐ @item.Rating/5
                    </span>
                </div>

                <div class="p-5">
                    <div class="flex items-center mb-2">
                        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">
                            @item.Restaurant?.Name
                        </span>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900 mb-2 truncate">@item.Title</h2>
                    <p class="text-gray-600 text-sm line-clamp-2 mb-4">
                        @item.Content
                    </p>

                    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                        <div class="flex items-center">
                            <div class="w-8 h-8 rounded-full bg-orange-500 flex items-center justify-center text-white font-bold text-xs">
                                @item.User?.FullName?.Substring(0, 1)
                            </div>
                            <span class="ml-2 text-xs text-gray-500">@item.User?.FullName</span>
                        </div>
                        <a href="@Url.Action("Details", "Post", new { id = item.Id })"
                               class="text-blue-600 font-bold text-sm hover:underline">
                            Xem thêm →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>