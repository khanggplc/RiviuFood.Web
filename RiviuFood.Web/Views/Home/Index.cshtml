@model IEnumerable<RiviuFood.Web.Models.Entities.Post>

<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-10">
        <h2 class="text-3xl font-black text-gray-900">🔥 Khám phá món ngon</h2>
        <a asp-controller="Post" asp-action="Create" class="bg-orange-600 text-white px-6 py-3 rounded-full font-bold shadow-lg hover:bg-orange-700 transition">
            + Viết Review
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var post in Model)
        {
            <div class="bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 group">
                <div class="relative h-64 overflow-hidden">
                    <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/images/no-image.jpg" : post.ImageUrl)"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-orange-600">
                        ⭐ @post.Rating / 5
                    </div>
                </div>

                <div class="p-6">
                    <span class="text-blue-600 text-xs font-bold uppercase tracking-wider">@post.Restaurant?.Name</span>
                    <h3 class="text-xl font-bold text-gray-900 mt-1 mb-3 line-clamp-1">
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="hover:text-orange-600">
                            @post.Title
                        </a>
                    </h3>
                    <p class="text-gray-500 text-sm line-clamp-2 mb-4">@post.Content</p>
                    
                    <div class="flex items-center justify-between pt-4 border-t border-gray-50">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold">
                                @post.User?.UserName?.Substring(0, 1).ToUpper()
                            </div>
                            <span class="text-xs font-medium text-gray-600">@post.User?.UserName</span>
                        </div>
                        <span class="text-[10px] text-gray-400">@post.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>
        }
        @using X.PagedList.Mvc.Core;
        @using X.PagedList.Web.Common;

        <div class="flex justify-center mt-12 mb-10">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
                new PagedListRenderOptions
                {
                    LiElementClasses = new string[] { "mx-1" },
                    PageClasses = new string[] { "px-4 py-2 rounded-xl bg-white border border-gray-200 text-gray-700 hover:bg-orange-500 hover:text-white transition-all font-bold shadow-sm" },
                    UlElementClasses = new string[] { "flex items-center" },
                    ContainerDivClasses = new string[] { "pagination-container" },
                    ActiveLiElementClasses = new string[] { "active-page" } // Cần thêm CSS để đổi màu nút hiện tại
                })
        </div>

        <style>
                    /* CSS nhỏ để làm nổi bật trang đang xem */
                    .active-page a {
                        background-color: #ea580c !important; /* màu orange-600 */
                        color: white !important;
                        border-color: #ea580c !important;
                    }
        </style>
    </div>
</div>